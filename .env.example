# =============================================================================
# Resume Tailor — copy to .env and fill in secrets
#   cp .env.example .env
# =============================================================================

OPENAI_API_KEY=

# Plain-text inputs (required)
RESUME_TEXT_PATH=input/resume.txt
JOB_DESCRIPTION_TEXT_PATH=input/job_description.txt

# Reference PDF for layout (agents see path in prompts; file ships as input/resume_template.pdf)
TEMPLATE_PDF_PATH=input/resume_template.pdf

OUTPUT_DIR=output

# Legacy aliases still supported in main.py:
# RESUME_PATH=input/resume.txt
# JOB_DESCRIPTION_PATH=input/job_description.txt
